# Kopiere diese Datei nach `.env` und passe die Pfade an.

# Pfad zu den Bildern. Jeder Unterordner = Album.
# Beispiel fï¿½r SMB-Mount auf Linux: /mnt/vega-gallery
PHOTOS_PATH=/mnt/vega-gallery

# Wo Thumbnails und SQLite-DB landen (kï¿½nnen lokal bleiben, mï¿½ssen nicht auf SMB)
THUMBS_PATH=./thumbnails
DATA_PATH=./data

# Port auf dem Host
PORT=8000

# Max-Kante der Vorschaubilder in Pixeln
THUMB_SIZE=480

# Periodischer Rescan in Sekunden (0 = aus).
# Empfohlen fï¿½r SMB/CIFS/NFS, weil inotify dort nicht zuverlï¿½ssig feuert.
# 300 = alle 5 Minuten
SCAN_INTERVAL=300

# Datei-Watcher aktivieren (1/0). Auf SMB bringt der wenig, lokal sehr viel.
ENABLE_WATCHER=0

# GPS-Koordinaten aus EXIF ausblenden (1/0). Default 1 fï¿½r ï¿½ffentliches Hosting.
# Wenn 0: GPS-Koordinaten sind fï¿½r alle Besucher sichtbar.
HIDE_GPS=1
