# Kopiere diese Datei nach `.env` und passe die Pfade an.

# Pfad zu den Bildern. Jeder Unterordner = Album.
# Beispiel f�r SMB-Mount auf Linux: /mnt/vega-gallery
PHOTOS_PATH=/mnt/vega-gallery

# Wo Thumbnails und SQLite-DB landen (k�nnen lokal bleiben, m�ssen nicht auf SMB)
THUMBS_PATH=./thumbnails
DATA_PATH=./data

# Port auf dem Host
PORT=8000

# Max-Kante der Vorschaubilder in Pixeln
THUMB_SIZE=480

# Periodischer Rescan in Sekunden (0 = aus).
# Empfohlen f�r SMB/CIFS/NFS, weil inotify dort nicht zuverl�ssig feuert.
# 300 = alle 5 Minuten
SCAN_INTERVAL=300

# Datei-Watcher aktivieren (1/0). Auf SMB bringt der wenig, lokal sehr viel.
ENABLE_WATCHER=0

# === Sicherheit (wichtig f�r �ffentliches Hosting) ===

# Admin-Token f�r Schreib-Operationen (Rescan, Tags editieren).
# WENN LEER: Rescan- und Tag-Endpunkte sind komplett deaktiviert.
# WENN GESETZT: �ber den "Login"-Button im Web-UI eingeben.
# Mit `openssl rand -hex 32` einen starken Token generieren.
ADMIN_TOKEN=

# GPS-Koordinaten aus EXIF ausblenden (1/0). Default 1 f�r �ffentliches Hosting.
# Wenn 0: GPS-Koordinaten sind f�r alle Besucher sichtbar.
HIDE_GPS=1
