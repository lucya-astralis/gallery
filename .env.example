# Copy this file to `.env` and adjust paths.

# Path to your images. Each subfolder = album.
# Example for an SMB mount on Linux: /mnt/vega-gallery
PHOTOS_PATH=/mnt/vega-gallery

# Where thumbnails, previews and the SQLite DB live (can stay local, no need for SMB)
THUMBS_PATH=./thumbnails
PREVIEWS_PATH=./previews
DATA_PATH=./data

# Host port
PORT=8000

# Max edge of the grid thumbnails in pixels
THUMB_SIZE=480

# Max edge of the stage previews in pixels (large preview on the detail page)
PREVIEW_SIZE=1600

# Periodic rescan in seconds (0 = off).
# Recommended for SMB/CIFS/NFS because inotify doesn't fire reliably there.
# 300 = every 5 minutes
SCAN_INTERVAL=300

# Enable file watcher (1/0). On SMB it adds little, locally it adds a lot.
ENABLE_WATCHER=0

# Strip GPS coordinates from EXIF display (1/0). Default 1 for public hosting.
HIDE_GPS=1
